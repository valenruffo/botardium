# =========================================
# Botardium - Variables de Entorno
# =========================================
# Copia este archivo a .env y completá los valores.
# NUNCA commitear .env al repositorio.

# --- Instagram ---
IG_USERNAME=
IG_PASSWORD=

# --- Tipo de Cuenta (Account DNA) ---
# personal = Cuenta principal, IP fija, conservadora
# prospector = Cuenta nueva, rotación IP, escalado progresivo
ACCOUNT_TYPE=personal

# --- Proxies ---
PROXY_URL=
# Formato: http://user:pass@host:port o socks5://host:port

# --- ADB (Android Debug Bridge) ---
ADB_HOST=127.0.0.1
ADB_PORT=5037
ADB_DEVICE=
# Dejar vacío para auto-detect del primer dispositivo

# --- API Keys (LLM) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Browser Use ---
BROWSER_USE_API_KEY=

# --- DDGS (Search) ---
# No requiere API key, pero se puede configurar proxy
DDGS_PROXY=
