# =========================================
# PrimeBot Core - Variables de Entorno
# =========================================
# Copia este archivo a .env y completá los valores.
# NUNCA commitear .env al repositorio.

# --- Instagram ---
IG_USERNAME=
IG_PASSWORD=

# --- Proxies ---
PROXY_URL=
# Formato: http://user:pass@host:port o socks5://host:port

# --- API Keys (LLM) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Browser Use ---
BROWSER_USE_API_KEY=

# --- DDGS (Search) ---
# No requiere API key, pero se puede configurar proxy
DDGS_PROXY=
