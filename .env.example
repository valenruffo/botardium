# =========================================
# Botardium - Variables de Entorno
# =========================================
# Copia este archivo a .env y completá los valores.
# NUNCA commitear .env al repositorio.

# --- Instagram ---
IG_USERNAME=
IG_PASSWORD=

# --- Tipo de Cuenta (Account DNA) ---
ACCOUNT_TYPE=personal

# --- Proxies (Opcional) ---
PROXY_URL=

# --- ADB (Opcional) ---
ADB_HOST=127.0.0.1
ADB_PORT=5037
ADB_DEVICE=

# --- API Keys (LLM) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_FLASH_MODEL=gemini-3-flash
OPENAI_MESSAGE_MODEL=gpt-4o-mini

# --- Otros proveedores opcionales ---
ANTHROPIC_API_KEY=
BROWSER_USE_API_KEY=
DDGS_PROXY=
