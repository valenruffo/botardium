# =========================================
# Botardium - Variables de Entorno
# =========================================
# Copia este archivo a .env y completá los valores.
# NUNCA commitear .env al repositorio.

# --- Instagram ---
IG_USERNAME=
IG_PASSWORD=

# --- Tipo de Cuenta (Account DNA) ---
ACCOUNT_TYPE=personal

# --- Proxies (Opcional) ---
PROXY_URL=

# --- ADB (Opcional) ---
ADB_HOST=127.0.0.1
ADB_PORT=5037
ADB_DEVICE=

# --- API Keys (bootstrap only) ---
# Las claves globales de abajo sirven como fallback local/CI.
# Las claves por workspace ahora se guardan en el runtime local
# (`config/runtime_secrets.json`) y no se exportan ni importan.
GOOGLE_API_KEY=
GOOGLE_FLASH_MODEL=gemini-3-flash-preview

# --- Otros proveedores opcionales ---
ANTHROPIC_API_KEY=
BROWSER_USE_API_KEY=
DDGS_PROXY=

# --- OpenCode / MCP ---
CONTEXT7_API_KEY=
GITHUB_TOKEN=
TESTSPRITE_API_KEY=
